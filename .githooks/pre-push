#!/usr/bin/env bash
# .githooks/pre-push
# Fast local checks that run before every push.
# These are lightweight (< 2 min) — no C++ builds, no tests, no coverage.
#
# Full verification (build, test, coverage, sanitisers) runs in CI
# via scripts/ci/nightly/*.sh and GitHub Actions.
#
# Skip with: SKIP_PREPUSH=1 git push

set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [ "${SKIP_PREPUSH:-0}" = "1" ]; then
  echo "Pre-push checks skipped (SKIP_PREPUSH=1)."
  exit 0
fi

for script in "$ROOT"/scripts/ci/pre-push/*.sh; do
  [ -f "$script" ] || continue
  bash "$script"
done

echo "Pre-push checks passed."
echo "Full build + test verification runs in CI (scripts/ci/nightly/)."
