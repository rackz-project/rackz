#!/usr/bin/env bash
# .githooks/prepare-commit-msg
# Thin wrapper — all logic lives in scripts/ci/prepare-commit-msg/

set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

for script in "$ROOT"/scripts/ci/prepare-commit-msg/*.sh; do
  [ -f "$script" ] || continue
  bash "$script" "$1" "${2:-}" "${3:-}"
done
